# Server
PORT=4000
NODE_ENV=development

# Database
# Postgres example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/esrs?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/esrs?schema=public"

# Auth
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="8h"

# File uploads
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=10

# PSGC source
PSGC_BASE_URL="https://psgc.cloud/api"
