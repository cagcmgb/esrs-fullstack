generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CENTRAL_OFFICE
  REGIONAL_ECONOMIST
  GUEST
}

enum MineralType {
  METALLIC
  NON_METALLIC
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
}

enum PeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ReportType {
  OPERATING_MINES
  DIRECTORY
  PRODUCTION
  SALES
  EXPORT_BY_COUNTRY
  EMPLOYMENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         UserRole
  /// For Regional Economist users, optionally lock them to a PSGC region code.
  regionCode   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissionsCreated    Submission[]          @relation("SubmissionCreatedBy")
  submissionsVerified   Submission[]          @relation("SubmissionVerifiedBy")
  contractorsVerified   Contractor[]          @relation("ContractorVerifiedBy")
  contractorsCreated    Contractor[]          @relation("ContractorCreatedBy")
  contractorHistories   ContractorHistory[]   @relation("ContractorHistoryChangedBy")
  exchangeRateOverrides ExchangeRateOverride[] @relation("ExchangeRateOverrideBy")
  exciseTaxOverrides    ExciseTaxOverride[]   @relation("ExciseTaxOverrideBy")
}

model PermitType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  permits Permit[]
}

model ContractorStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  contractors Contractor[]
}

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  symbol    String?
  createdAt DateTime @default(now())

  commodities Commodity[]
}

model Commodity {
  id               String      @id @default(cuid())
  name             String      @unique
  mineralType      MineralType
  category         String?
  defaultUnitId    String?
  defaultUnit      Unit?       @relation(fields: [defaultUnitId], references: [id])
  /// Optional mapping to a specific MGB form template code (e.g., "MGB29-01").
  formTemplateCode String?
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())

  contractorCommodities ContractorCommodity[]
  submissions           Submission[]
}

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

/// Configuration for contractor ID numbering per region.
model RegionConfig {
  regionCode   String   @id
  regionName   String
  /// Prefix used when assigning contractor codes (e.g., "R2", "R4A", "NCR").
  idPrefix     String
  nextSequence Int      @default(1)
  updatedAt    DateTime @updatedAt
}

model Contractor {
  id             String  @id @default(cuid())
  /// Assigned after verification (e.g., R2-001)
  contractorCode String? @unique

  name         String
  tin          String
  operatorName String
  contactNo    String
  email        String

  regionCode       String
  regionName       String
  provinceCode     String?
  provinceName     String
  municipalityCode String?
  municipalityName String

  areaHectare Float

  statusId String
  status   ContractorStatus @relation(fields: [statusId], references: [id])

  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?     @relation("ContractorVerifiedBy", fields: [verifiedById], references: [id])

  createdById String?
  createdBy   User?   @relation("ContractorCreatedBy", fields: [createdById], references: [id])

  permits               Permit[]
  contractorCommodities ContractorCommodity[]
  contractorDocuments   ContractorDocument[]
  submissions           Submission[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  contractorHistories ContractorHistory[]
}

model ContractorHistory {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  changedById String?
  changedBy   User?   @relation("ContractorHistoryChangedBy", fields: [changedById], references: [id])

  data      Json
  createdAt DateTime @default(now())

  @@index([contractorId])
}

model Permit {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  permitTypeId String
  permitType   PermitType @relation(fields: [permitTypeId], references: [id])

  permitNumber   String
  dateApproved   DateTime?
  dateExpiration DateTime?

  createdAt DateTime @default(now())

  @@index([contractorId])
}

model ContractorCommodity {
  contractorId String
  commodityId  String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  commodity    Commodity  @relation(fields: [commodityId], references: [id])

  @@id([contractorId, commodityId])
}

model Submission {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  commodityId String
  commodity   Commodity @relation(fields: [commodityId], references: [id])

  periodType PeriodType
  year       Int
  month      Int?
  quarter    Int?

  status         SubmissionStatus @default(DRAFT)
  rejectedReason String?

  /// Flexible section payloads (aligned to MGB Form 29 templates).
  administrative Json?
  production     Json?
  sales          Json?
  employment     Json?

  createdById String
  createdBy   User   @relation("SubmissionCreatedBy", fields: [createdById], references: [id])

  submittedAt DateTime?

  verifiedById String?
  verifiedBy   User?     @relation("SubmissionVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?

  attachments          Attachment[]
  exchangeRateOverride ExchangeRateOverride[]
  exciseTaxOverride    ExciseTaxOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractorId, commodityId, periodType, year, month, quarter])
  @@index([year, month, quarter])
}

model Attachment {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  originalName String
  mimeType     String
  fileName     String
  filePath     String
  sizeBytes    Int
  uploadedAt   DateTime @default(now())

  @@index([submissionId])
}

enum DocumentType {
  BUSINESS_PERMIT
  SAFETY_CERTIFICATION
  INSURANCE_DOCUMENT
  COMPLIANCE_CERTIFICATE
}

model ContractorDocument {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  type         DocumentType
  originalName String
  mimeType     String
  fileName     String
  filePath     String
  sizeBytes    Int
  uploadedAt   DateTime @default(now())

  @@index([contractorId])
}

model ReportPermission {
  id         String     @id @default(cuid())
  role       UserRole
  reportType ReportType
  canView    Boolean    @default(true)

  @@unique([role, reportType])
}

/// Monthly average exchange rates keyed by currency pair + year + month.
model HistoricalExchangeRate {
  id           String   @id @default(cuid())
  /// Currency pair in the form "USD/PHP"
  currencyPair String
  year         Int
  month        Int
  /// Monthly average rate (e.g., 58.40 for USD→PHP)
  rate         Decimal  @db.Decimal(18, 6)
  /// Source of the rate: BSP, MGB, manual, etc.
  source       String   @default("manual")
  fetchedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([currencyPair, year, month])
  @@index([year, month])
}

/// Date-effective excise tax rate configuration (supports RA changes over time).
model ExciseTaxConfig {
  id           String   @id @default(cuid())
  /// The date from which this rate is effective (inclusive)
  effectiveFrom DateTime
  /// The date until which this rate is effective (inclusive), null = open-ended
  effectiveTo   DateTime?
  /// Tax rate as a decimal (e.g., 0.04 for 4%)
  rate          Decimal  @db.Decimal(8, 6)
  /// Legal reference e.g. "RA 12253"
  legalBasis    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([effectiveFrom])
}

/// Per-submission exchange rate override with audit trail.
model ExchangeRateOverride {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  currencyPair String
  officialRate Decimal  @db.Decimal(18, 6)
  overrideRate Decimal  @db.Decimal(18, 6)
  reason       String
  overriddenById String
  overriddenBy   User   @relation("ExchangeRateOverrideBy", fields: [overriddenById], references: [id])
  createdAt    DateTime @default(now())

  @@index([submissionId])
}

/// Per-submission excise tax override with audit trail.
model ExciseTaxOverride {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  officialRate Decimal  @db.Decimal(8, 6)
  overrideRate Decimal  @db.Decimal(8, 6)
  reason       String
  overriddenById String
  overriddenBy   User   @relation("ExciseTaxOverrideBy", fields: [overriddenById], references: [id])
  createdAt    DateTime @default(now())

  @@index([submissionId])
}
